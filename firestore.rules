rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function profile() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function active() { return signedIn() && profile().ativo == true; }
    function admin() {
      return active() && profile().perfil in ['Desenvolvedor/Admin', 'Administrador', 'desenvolvedor', 'admin'];
    }
    function manager() { return active() && profile().perfil in ['Gestor', 'gestor']; }
    function operational() { return active() && profile().perfil in ['Supervisor', 'supervisor', 'Gestor', 'gestor', 'Administrador', 'admin', 'Desenvolvedor/Admin', 'desenvolvedor']; }
    function visitor() { return active() && profile().perfil in ['Visitante', 'visitante']; }

    match /users/{uid} {
      allow read: if active() && (request.auth.uid == uid || admin());
      allow create: if admin() || (signedIn() && request.auth.uid == uid);
      allow update: if admin() || (
        signedIn() && request.auth.uid == uid &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['primeiroAcesso', 'deveAlterarSenha', 'ultimoLogin', 'updatedAt'])
      );
      allow delete: if admin() && request.auth.uid != uid;
    }
    match /inspections/{id} {
      allow read: if active();
      allow create, update: if operational() && !visitor() &&
        (!('fotosAntes' in request.resource.data) || request.resource.data.fotosAntes.size() <= 3) &&
        (!('fotosDepois' in request.resource.data) || request.resource.data.fotosDepois.size() <= 3);
      allow delete: if admin();
    }
    match /supervisors/{id} {
      allow read: if active();
      allow write: if admin();
    }
    match /areas/{id} {
      allow read: if active();
      allow write: if admin();
    }
    match /contracts/{id} {
      allow read: if active();
      allow write: if admin();
    }
    match /settings/{id} {
      allow read: if active();
      allow write: if admin();
    }
    match /notifications/{id} {
      allow read: if active();
      allow create, update: if active() && !visitor();
      allow delete: if admin();
    }
    match /authorized_emails/{id} {
      allow read: if active();
      allow write: if admin();
    }
    match /deleted_names/{id} {
      allow read: if active();
      allow write: if admin();
    }
    match /auditLogs/{id} {
      allow read: if admin();
      allow create: if active();
      allow update, delete: if false;
    }
    match /{document=**} { allow read, write: if false; }
  }
}
